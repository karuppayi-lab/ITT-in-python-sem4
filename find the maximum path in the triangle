T = int(input("Enter the no:of test cases:"))
for i in range(T):
   N=int(input("Ente the no:of rows:"))
   res=[list(map(int,input().split())) for j in range(N)]
   for i in range(N-2,-1,-1):
      for j in range(i+1):
         res[i][j]+=max(res[i+1][j],res[i+1][j+1])
   print("Max path:",res[0][0])
