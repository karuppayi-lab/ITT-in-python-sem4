class Solution:
    def convert(self, s: str, numRows: int) -> str:
        if numRows==1 or numRows>=len(s):
            return s
        res=[]
        length=2*numRows-2
        for i in range(numRows):
            for j in range(0,len(s)-i,length):
                res.append(s[j+i])
                if i!=0 and i!=numRows-1 and j+length-i<len(s):
                    res.append(s[j+length-i])
        return "".join(res)

sol=Solution()
re=sol.convert("PAYPALISHIRING",3)
print(re)
